"""
HiringAgent — "Who do we need?"

Responsible for identifying hiring needs, defining roles,
creating job descriptions, evaluating candidates, and
building hiring plans that align with project goals.
"""

from __future__ import annotations

from typing import Optional

from nexus.core.base_agent import BaseAgent, AgentResponse
from nexus.core.event_bus import EventBus
from nexus.core.registry import register_agent
from nexus.core.world_model import WorldModel


@register_agent
class HiringAgent(BaseAgent):
    name = "hiring_agent"
    description = (
        "You determine staffing needs, define roles, evaluate candidates, "
        "and recommend hiring strategies for successful project delivery."
    )

    def __init__(
        self,
        world: WorldModel,
        bus: Optional[EventBus] = None,
        **kwargs,
    ):
        super().__init__(world, bus, **kwargs)

    def identify_hiring_needs(self) -> AgentResponse:
        """
        Determine additional staffing requirements.
        """

        return self.run(
            "Review the current project plan, implementation roadmap, "
            "team capacity, and workload. Identify any additional roles "
            "required to successfully complete the project."
        )

    def define_role(self) -> AgentResponse:
        """
        Create role definitions.
        """

        return self.run(
            "Create detailed role definitions for each recommended "
            "position. Include responsibilities, required skills, "
            "experience, qualifications, and expected outcomes."
        )

    def create_job_description(self) -> AgentResponse:
        """
        Generate job descriptions.
        """

        return self.run(
            "Generate professional job descriptions for all open "
            "positions, including responsibilities, qualifications, "
            "preferred experience, and reporting structure."
        )

    def evaluate_candidates(self) -> AgentResponse:
        """
        Assess candidate suitability.
        """

        return self.run(
            "Review available candidate information and evaluate each "
            "candidate against the project's staffing requirements. "
            "Highlight strengths, weaknesses, and overall fit."
        )

    def recommend_hiring_plan(self) -> AgentResponse:
        """
        Develop a hiring roadmap.
        """

        return self.run(
            "Develop a hiring plan that prioritizes critical positions, "
            "defines recruitment timelines, estimates hiring costs, and "
            "identifies recruitment risks."
        )

    def forecast_staffing(self) -> AgentResponse:
        """
        Forecast future staffing needs.
        """

        return self.run(
            "Forecast staffing requirements across the remaining project "
            "timeline. Identify when new hires or contractors may be "
            "needed and estimate the impact on delivery."
        )

    def handle_event(
        self,
        description: str,
    ) -> AgentResponse:
        """
        Respond to hiring-related events.
        """

        return self.run(
            f"A staffing event occurred: '{description}'. "
            "Determine how this affects hiring priorities, recruitment "
            "plans, team capacity, and project delivery. Recommend "
            "appropriate actions."
        )
